{% extends 'base.html.twig' %}

{% block title %}Gestion des catégories{% endblock %}

{% block body %}
    <div class="container">
        <h1>Gestion des catégories</h1>

        <a href="{{ path('app_admin_category_new') }}" class="btn btn-success mb-3">Ajouter une catégorie</a>

        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Nombre de livres</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for category in categories %}
                        <tr>
                            <td>{{ category.name }}</td>
                            <td><span class="badge bg-info">{{ category.books|length }}</span></td>
                            <td>
                                <a href="{{ path('app_admin_category_edit', {'id': category.id}) }}" class="btn btn-primary btn-sm">Éditer</a>
                                <form method="post" action="{{ path('app_admin_category_delete', {'id': category.id}) }}" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                                    <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="text-center">Aucune catégorie</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <a href="{{ path('app_admin_dashboard') }}" class="btn btn-secondary mt-3">Retour au dashboard</a>
    </div>
{% endblock %}
