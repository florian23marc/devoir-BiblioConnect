{% extends 'base.html.twig' %}

{% block title %}Éditer une langue{% endblock %}

{% block body %}
    <div class="container">
        <h1>Éditer la langue: {{ language.name }}</h1>

        <form method="post" class="mt-4">
            <div class="mb-3">
                <label for="name" class="form-label">Nom de la langue</label>
                <input type="text" class="form-control" id="name" name="name" value="{{ language.name }}" required>
            </div>

            <button type="submit" class="btn btn-primary">Mettre à jour</button>
            <a href="{{ path('app_admin_language_index') }}" class="btn btn-secondary">Annuler</a>
        </form>
    </div>
{% endblock %}
