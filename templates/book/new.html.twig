{% extends 'base.html.twig' %}

{% block title %}Ajouter un livre{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row">
            <div class="col-md-8 mx-auto">
                <h1 class="mb-4">Ajouter un nouveau livre</h1>

                {{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.title) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.author) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_row(form.description) }}
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.stock) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.language) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.image) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.categories) }}
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a href="{{ path('app_book_index') }}" class="btn btn-secondary">Annuler</a>
                        <button type="submit" class="btn btn-primary">Sauvegarder le livre</button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}