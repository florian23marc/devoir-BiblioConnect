{% extends 'base.html.twig' %}

{% block title %}Catalogue de Livres{% endblock %}

{% block body %}
    <div class="mb-5">
        <h1 class="mb-1"><i class="fas fa-books text-primary"></i> Notre Catalogue</h1>
        <p class="text-muted">Découvrez nos milliers de livres</p>
    </div>

    <!-- Formulaire de recherche -->
    <div class="card mb-4" style="background: linear-gradient(135deg, rgba(37, 99, 235, 0.1) 0%, rgba(30, 64, 175, 0.1) 100%); border: 2px solid #e5e7eb;">
        {{ form_start(searchForm, {'method': 'GET', 'attr': {'class': 'mb-0'}}) }}
            <div class="card-body">
                <h5 class="card-title mb-3"><i class="fas fa-filter"></i> Filtrer votre recherche</h5>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label"><i class="fas fa-book"></i> Titre du livre</label>
                        {{ form_widget(searchForm.title, {'attr': {'class': 'form-select'}}) }}
                    </div>
                    <div class="col-md-3">
                        <label class="form-label"><i class="fas fa-pen-fancy"></i> Auteur</label>
                        {{ form_widget(searchForm.author, {'attr': {'class': 'form-select'}}) }}
                    </div>
                    <div class="col-md-3">
                        <label class="form-label"><i class="fas fa-tag"></i> Catégorie</label>
                        {{ form_widget(searchForm.category, {'attr': {'class': 'form-select'}}) }}
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        {{ form_widget(searchForm.search, {'attr': {'class': 'btn btn-primary w-100'}}) }}
                    </div>
                </div>
            </div>
        {{ form_end(searchForm) }}
    </div>

    {% if is_granted('ROLE_LIBRARIAN') or is_granted('ROLE_ADMIN') %}
        <div class="mb-4">
            <a href="{{ path('app_book_new') }}" class="btn btn-success">
                <i class="fas fa-plus"></i> Ajouter un livre
            </a>
        </div>
    {% endif %}

    {% if books|length == 0 %}
        <div class="alert alert-info text-center py-4">
            <h5><i class="fas fa-inbox"></i> Aucun livre trouvé</h5>
            <p class="mb-0">Essayez de modifier vos critères de recherche</p>
        </div>
    {% else %}
        <div class="row g-4">
            {% for book in books %}
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0" style="transition: all 0.3s ease;">
                        <div style="position: relative; height: 280px; overflow: hidden; border-radius: 15px 15px 0 0; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                            {% if book.image %}
                                <img src="{{ asset('uploads/images/' ~ book.image) }}" class="card-img-top" alt="{{ book.title }}" style="height: 100%; object-fit: cover; width: 100%;">
                            {% else %}
                                <div class="d-flex align-items-center justify-content-center h-100" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                    <i class="fas fa-book fa-5x text-white"></i>
                                </div>
                            {% endif %}
                            <span class="badge bg-primary position-absolute top-2 end-2">Stock: {{ book.stock }}</span>
                        </div>

                        <div class="card-body">
                            <h5 class="card-title" style="color: #1f2937; font-weight: 700;">{{ book.title }}</h5>
                            <p class="card-text text-muted mb-2">
                                <i class="fas fa-pen-fancy"></i> {{ book.author }}
                            </p>

                            {% if book.categories|length > 0 %}
                                <div class="mb-3">
                                    {% for category in book.categories %}
                                        <span class="badge bg-light text-primary">{{ category.name }}</span>
                                    {% endfor %}
                                </div>
                            {% endif %}

                            {% if is_granted('ROLE_ADMIN') %}
                                <p class="card-text small text-muted mb-2">
                                    <i class="fas fa-globe"></i> {{ book.language ? book.language.name : 'Non spécifiée' }}
                                </p>
                            {% endif %}

                            <div class="d-flex gap-2 mt-3 flex-wrap">
                                <a href="{{ path('app_book_show', {'id': book.id}) }}" class="btn btn-primary btn-sm flex-grow-1">
                                    <i class="fas fa-eye"></i> Voir détails
                                </a>
                                {% if is_granted('ROLE_LIBRARIAN') or is_granted('ROLE_ADMIN') %}
                                    <a href="{{ path('app_book_edit', {'id': book.id}) }}" class="btn btn-outline-secondary btn-sm">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                {% endif %}
                                {% if is_granted('ROLE_ADMIN') %}
                                    <form method="post" action="{{ path('app_book_delete', {'id': book.id}) }}" onsubmit="return confirm('Êtes-vous sûr ?')" style="display: inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ book.id) }}">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}