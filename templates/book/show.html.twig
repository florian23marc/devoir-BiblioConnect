{% extends 'base.html.twig' %}

{% block title %}{{ book.title }}{% endblock %}

{% block body %}
    <div class="container py-5">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_book_index') }}">Livres</a></li>
                <li class="breadcrumb-item active" aria-current="page">{{ book.title }}</li>
            </ol>
        </nav>

        <!-- Book Details -->
        <div class="row mb-5">
            <!-- Book Image -->
            <div class="col-lg-4 mb-4">
                <div class="card shadow-sm border-0 sticky-top" style="top: 80px;">
                    {% if book.image %}
                        <img src="{{ asset('uploads/images/' ~ book.image) }}" class="card-img-top" alt="{{ book.title }}">
                    {% else %}
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center">
                            <i class="fas fa-book fa-5x text-muted"></i>
                        </div>
                    {% endif %}
                    <div class="card-body">
                        <!-- Average Rating -->
                        {% set total_rating = 0 %}
                        {% for review in book.reviews %}
                            {% set total_rating = total_rating + review.rating %}
                        {% endfor %}
                        {% set avg_rating = book.reviews|length > 0 ? (total_rating / book.reviews|length) : 0 %}
                        <div class="mb-3">
                            <div class="d-flex align-items-center">
                                <span class="text-warning">
                                    {% for i in 1..5 %}
                                        {% if i <= avg_rating %}
                                            <i class="fas fa-star"></i>
                                        {% elseif i - avg_rating < 1 %}
                                            <i class="fas fa-star-half-alt"></i>
                                        {% else %}
                                            <i class="far fa-star"></i>
                                        {% endif %}
                                    {% endfor %}
                                </span>
                                <span class="ms-2 text-muted small">{{ avg_rating|round(1, 'floor') }}/5 ({{ book.reviews|length }} avis)</span>
                            </div>
                        </div>

                        <!-- Stock Info -->
                        <div class="mb-3">
                            <h6 class="text-muted">Disponibilité</h6>
                            {% if availableStock > 0 %}
                                <span class="badge bg-success">En stock ({{ availableStock }} exemplaires)</span>
                            {% else %}
                                <span class="badge bg-danger">Rupture de stock</span>
                            {% endif %}
                        </div>

                        <!-- Action Buttons -->
                        {% if app.user %}
                            <div class="d-grid gap-2">
                                {% if availableStock > 0 %}
                                    <a href="{{ path('app_reservation_new', {'book': book.id}) }}" class="btn btn-primary">
                                        <i class="fas fa-calendar-alt"></i> Réserver
                                    </a>
                                {% else %}
                                    <button class="btn btn-primary" disabled>Réserver</button>
                                {% endif %}
                                <a href="{{ path('app_favorite_toggle', {'book': book.id}) }}" class="btn btn-outline-warning">
                                    <i class="fas fa-heart"></i> Ajouter aux favoris
                                </a>
                                <a href="{{ path('app_review_new', {'book': book.id}) }}" class="btn btn-outline-info">
                                    <i class="fas fa-comment"></i> Noter et commenter
                                </a>
                            </div>
                        {% endif %}

                        <!-- Admin Buttons -->
                        {% if is_granted('ROLE_LIBRARIAN') %}
                            <hr>
                            <div class="d-grid gap-2">
                                <a href="{{ path('app_book_edit', {'id': book.id}) }}" class="btn btn-secondary btn-sm">
                                    <i class="fas fa-edit"></i> Modifier
                                </a>
                                <form method="post" action="{{ path('app_book_delete', {'id': book.id}) }}" onsubmit="return confirm('Êtes-vous sûr ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ book.id) }}">
                                    <button type="submit" class="btn btn-danger btn-sm w-100">
                                        <i class="fas fa-trash"></i> Supprimer
                                    </button>
                                </form>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- Book Information -->
            <div class="col-lg-8">
                <div class="mb-4">
                    <h1 class="mb-3">{{ book.title }}</h1>
                    <h5 class="text-muted mb-4">par <strong>{{ book.author }}</strong></h5>
                </div>

                <!-- Description -->
                <div class="card mb-4 border-0 bg-light">
                    <div class="card-body">
                        <h6 class="card-title text-uppercase text-muted">Description</h6>
                        <p class="card-text">{{ book.description ?: 'Aucune description disponible.' }}</p>
                    </div>
                </div>

                <!-- Book Metadata -->
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="card border-0 bg-light">
                            <div class="card-body">
                                <h6 class="card-title text-muted text-uppercase small">Langue</h6>
                                <p class="mb-0">
                                    <strong>{{ book.language.name }}</strong>
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="col-sm-6">
                        <div class="card border-0 bg-light">
                            <div class="card-body">
                                <h6 class="card-title text-muted text-uppercase small">Catégories</h6>
                                <p class="mb-0">
                                    {% if book.categories|length > 0 %}
                                        {% for category in book.categories %}
                                            <span class="badge bg-primary">{{ category.name }}</span>
                                        {% endfor %}
                                    {% else %}
                                        <span class="text-muted">Aucune catégorie</span>
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Reviews Section -->
        <div class="row">
            <div class="col-lg-8">
                <div class="mb-5">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2>Avis lecteurs</h2>
                        {% if app.user %}
                            <a href="{{ path('app_review_new', {'book': book.id}) }}" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-plus"></i> Ajouter un avis
                            </a>
                        {% endif %}
                    </div>

                    {% if book.reviews|length > 0 %}
                        <div class="space-y-3">
                            {% for review in book.reviews %}
                                <div class="card border-0 shadow-sm mb-3">
                                    <div class="card-body">
                                        <!-- Reviewer Info -->
                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <div>
                                                <h6 class="mb-1">{{ review.user.firstName }} {{ review.user.lastName }}</h6>
                                                <small class="text-muted">{{ review.createdAt|date('d F Y à H:i') }}</small>
                                            </div>
                                            <!-- Rating Stars -->
                                            <div class="text-warning">
                                                {% for i in 1..5 %}
                                                    {% if i <= review.rating %}
                                                        <i class="fas fa-star"></i>
                                                    {% else %}
                                                        <i class="far fa-star"></i>
                                                    {% endif %}
                                                {% endfor %}
                                                <span class="ms-2 text-dark fw-bold">{{ review.rating }}/5</span>
                                            </div>
                                        </div>

                                        <!-- Comment -->
                                        <p class="card-text mb-3">{{ review.comment ?: '<em class="text-muted">Aucun commentaire</em>'|raw }}</p>

                                        <!-- Admin Actions -->
                                        {% if is_granted('ROLE_ADMIN') %}
                                            <div class="d-flex justify-content-end">
                                                <form method="post" action="{{ path('app_review_delete', {'id': review.id}) }}" onsubmit="return confirm('Modérer cet avis ?')">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ review.id) }}">
                                                    <button type="submit" class="btn btn-danger btn-sm">
                                                        <i class="fas fa-trash"></i> Modérer
                                                    </button>
                                                </form>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="alert alert-info" role="alert">
                            <i class="fas fa-info-circle"></i> Aucun avis pour ce livre pour le moment.
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}