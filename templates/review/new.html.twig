{% extends 'base.html.twig' %}

{% block title %}Noter et commenter{% endblock %}

{% block body %}
    <div class="container py-5">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_book_index') }}">Livres</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_book_show', {'id': review.book.id}) }}">{{ review.book.title }}</a></li>
                <li class="breadcrumb-item active" aria-current="page">Noter et commenter</li>
            </ol>
        </nav>

        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-5">
                        <h1 class="card-title mb-2">Partagez votre avis</h1>
                        <p class="text-muted mb-4">
                            <strong>{{ review.book.title }}</strong> par {{ review.book.author }}
                        </p>

                        {% if app.flashes('success') %}
                            {% for message in app.flashes('success') %}
                                <div class="alert alert-success alert-dismissible fade show" role="alert">
                                    {{ message }}
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            {% endfor %}
                        {% endif %}

                        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                            <!-- Rating Field -->
                            <div class="mb-5">
                                {{ form_label(form.rating) }}
                                <div class="mt-3">
                                    {% for child in form.rating %}
                                        <div class="form-check mb-2">
                                            {{ form_widget(child, {'attr': {'class': 'form-check-input'}}) }}
                                            <label class="form-check-label" for="{{ child.vars.id }}">
                                                {{ child.vars.label }}
                                            </label>
                                        </div>
                                    {% endfor %}
                                </div>
                                {% if form.rating.vars.errors|length > 0 %}
                                    <div class="invalid-feedback d-block">
                                        {{ form_errors(form.rating) }}
                                    </div>
                                {% endif %}
                            </div>

                            <!-- Comment Field -->
                            <div class="mb-4">
                                {{ form_label(form.comment) }}
                                {{ form_widget(form.comment, {
                                    'attr': {
                                        'class': 'form-control'
                                    }
                                }) }}
                                <small class="form-text text-muted d-block mt-2">
                                    {{ form.comment.vars.help }}
                                </small>
                                {% if form.comment.vars.errors|length > 0 %}
                                    <div class="invalid-feedback d-block">
                                        {{ form_errors(form.comment) }}
                                    </div>
                                {% endif %}
                            </div>

                            <!-- Buttons -->
                            <div class="d-grid gap-2 d-sm-flex gap-2">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-paper-plane"></i> Soumettre mon avis
                                </button>
                                <a href="{{ path('app_book_show', {'id': review.book.id}) }}" class="btn btn-outline-secondary btn-lg">
                                    <i class="fas fa-times"></i> Annuler
                                </a>
                            </div>

                        {{ form_end(form) }}
                    </div>
                </div>

                <!-- Info Box -->
                <div class="alert alert-info mt-4" role="alert">
                    <h5 class="alert-heading"><i class="fas fa-lightbulb"></i> Conseil</h5>
                    <p class="mb-0">Votre avis doit être honnête et constructif. Les avis offensants ou hors sujet seront modérés par les administrateurs.</p>
                </div>
            </div>
        </div>
    </div>

    <style>
        .form-check-input {
            width: 1.25em;
            height: 1.25em;
            cursor: pointer;
        }
        
        .form-check-label {
            cursor: pointer;
            font-size: 1.05em;
            padding-left: 0.5rem;
        }
        
        .form-check-label:hover {
            color: #0d6efd;
        }
    </style>
{% endblock %}